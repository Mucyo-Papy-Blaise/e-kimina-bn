generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  USER
  SUPER_ADMIN
  GROUP_ADMIN
  TREASURER
  MEMBER
}

enum GroupMembershipStatus {
  ACTIVE
  SUSPENDED
}

enum GroupRemovalKind {
  REMOVED
  SUSPENDED
}

enum ContributionStatus {
  PENDING
  PAID
  LATE
}

enum ContributionInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum LoanApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum MemberLoanStatus {
  ACTIVE
  REPAID
  DEFAULTED
}

/// In-app user notifications (per-user rows; `audience` allows filtering by member vs admin vs treasurer).
enum NotificationType {
  /// Manual bank proof submitted; admins & treasurers should review
  DEPOSIT_MANUAL_PENDING
  /// MoMo or confirmed contribution deposit applied to the member
  DEPOSIT_RECORDED
  /// MoMo or confirmed payment applied to a loan
  LOAN_REPAYMENT_RECORDED
  /// Manual contribution proof was confirmed
  DEPOSIT_CONFIRMED
  /// Manual loan repayment proof was confirmed
  LOAN_REPAYMENT_APPLIED
  /// Manual transfer rejected
  DEPOSIT_REJECTED
  /// New loan application submitted
  LOAN_APPLICATION_SUBMITTED
  /// The other approver (admin or treasurer) must still approve
  LOAN_AWAITING_YOUR_APPROVAL
  /// Loan disbursed to borrower
  LOAN_DISBURSED
  /// Loan application rejected
  LOAN_REJECTED
  /// Another admin confirmed a manual deposit (audit for leadership)
  MANUAL_DEPOSIT_AUDIT_CONFIRM
  /// Another admin rejected a manual deposit
  MANUAL_DEPOSIT_AUDIT_REJECT
  /// Member submitted manual payment proof (pending review)
  PAYMENT_PROOF_SUBMITTED
  /// User was added to a group (invite or self-join)
  ADDED_TO_GROUP
  /// Group admin / treasurer: a new member joined or was added
  NEW_GROUP_MEMBER
  /// Invited by email but must still complete registration (stored for when they log in)
  GROUP_INVITATION_PENDING
}

enum NotificationAudience {
  MEMBER
  GROUP_ADMIN
  TREASURER
}

enum DepositPaymentMethod {
  MTN_MOMO
  MANUAL_TRANSFER
}

enum DepositRecordStatus {
  PENDING
  PENDING_VERIFICATION
  CONFIRMED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  phoneNumber  String?
  image        String?
  isActive     Boolean @default(true)
  /// Set true after sign-up OTP or treasurer invitation completion.
  emailVerified              Boolean   @default(false)
  emailVerificationOtpHash   String?
  emailVerificationExpiresAt DateTime?
  passwordResetOtpHash       String?
  passwordResetExpiresAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  platformRoles UserPlatformRole[]
  userGroups    UserGroup[]
  createdGroups Group[]            @relation("GroupCreator")
  treasurerInvitations TreasurerInvitation[]
  memberInvitations    MemberInvitation[]
  groupRemovalNotifications GroupRemovalNotification[]
  userNotifications     UserNotification[]
  contributions Contribution[]
  loanApplications  LoanApplication[]
  loanGroupAdminApprovals  LoanApplication[] @relation("LoanAppGroupAdmin")
  loanTreasurerApprovals  LoanApplication[] @relation("LoanAppTreasurer")
  loanApplicationRejections LoanApplication[] @relation("LoanAppRejectedBy")
  memberLoans         MemberLoan[]
  depositRecords      DepositRecord[]
  depositReviews    DepositRecord[] @relation("DepositReviewedBy")

  @@map("users")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean @default(false)
  createdById String
  isVerified  Boolean  @default(true)

  minMembers  Int
  createdAt   DateTime @default(now())

  createdBy  User         @relation("GroupCreator", fields: [createdById], references: [id])
  userGroups UserGroup[]
  loanConfig LoanConfig?
  contributionConfig ContributionConfig?

  treasurerInvitations TreasurerInvitation[]
  memberInvitations    MemberInvitation[]
  contributions        Contribution[]
  loanApplications     LoanApplication[]
  memberLoans         MemberLoan[]
  depositRecords       DepositRecord[]
  userNotifications    UserNotification[]

  @@index([createdById])
  @@map("groups")
}

model Contribution {
  id        String   @id @default(cuid())
  userId    String
  groupId   String

  amount    Decimal  @db.Decimal(10, 2)
  dueDate   DateTime
  paidAt    DateTime?

  status    ContributionStatus @default(PENDING)

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, dueDate])
  @@index([groupId, dueDate])

  @@map("contributions")
}

model ContributionConfig {
  id        String @id @default(cuid())
  groupId   String @unique

  amount    Decimal @db.Decimal(10, 2)
  currency  String  @default("RWF")

  interval  ContributionInterval

  // Scheduling
  startDate DateTime
  dayOfWeek Int?   // 0–6 (for weekly/biweekly)
  dayOfMonth Int?  // 1–31 (for monthly)

  // Rules
  allowPartialPayments Boolean @default(false)
  latePenaltyRate      Decimal? @db.Decimal(5,2)
  gracePeriodDays      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("contribution_config")
}

/// One-time link for a pending treasurer to complete registration after group creation.
model TreasurerInvitation {
  id        String   @id @default(cuid())
  token     String   @unique
  groupId   String
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("treasurer_invitations")
}

/// One-time link for a pending member to complete registration after a group admin invite.
model MemberInvitation {
  id        String   @id @default(cuid())
  token     String   @unique
  groupId   String
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("member_invitations")
}

model Role {
  id   String   @id @default(cuid())
  name RoleName @unique

  platformAssignments UserPlatformRole[]
  userGroups          UserGroup[]

  @@map("roles")
}

/// Group membership: one role per user per group (relational RBAC).
model UserGroup {
  id                 String                 @id @default(cuid())
  userId             String
  groupId            String
  roleId             String
  joinedAt           DateTime               @default(now())
  membershipStatus   GroupMembershipStatus  @default(ACTIVE)
  customContributionAmount Decimal? @db.Decimal(10,2)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id])

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])

  @@map("user_groups")
}

/// In-app notice when a user is removed or suspended from a group (platform login unaffected).
model GroupRemovalNotification {
  id        String           @id @default(cuid())
  userId    String
  groupId   String
  groupName String
  kind      GroupRemovalKind
  reason    String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("group_removal_notifications")
}

/// Per-user in-app notification (one row per recipient).
model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  groupId   String?
  type      NotificationType
  audience  NotificationAudience
  title     String
  body      String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@index([userId, audience, readAt, createdAt(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
  @@map("user_notifications")
}

/// Platform-level role: default `USER`, elevated e.g. `SUPER_ADMIN`. Not tied to a group.
model UserPlatformRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@unique([userId])

  @@map("user_platform_role")
}

model LoanConfig {
  id                     String   @id @default(cuid())
  groupId                String   @unique

  interestRate           Decimal  @db.Decimal(5, 2)
  repaymentPeriodDays    Int

  allowExceedContribution Boolean @default(false)
  maxLoanMultiplier       Decimal? @db.Decimal(5, 2)

  allowPartialPayments    Boolean  @default(true)

  penaltyRate             Decimal? @db.Decimal(5, 2)
  gracePeriodDays         Int      @default(0)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("loan_config")
}

/// Member request for a loan; validated against `LoanConfig` and contribution totals.
/// Disbursement requires **both** group admin and treasurer approval (in any order).
model LoanApplication {
  id                          String                 @id @default(cuid())
  userId                      String
  groupId                     String
  requestedAmount             Decimal                @db.Decimal(10, 2)
  status                      LoanApplicationStatus  @default(PENDING)
  interestRateSnapshot        Decimal                @db.Decimal(5, 2)
  repaymentPeriodDaysSnapshot Int
  /// Max allowed at request time (audit / explain eligibility).
  maxAmountSnapshot           Decimal?               @db.Decimal(10, 2)
  /// Group admin approval slot (separate from treasurer; both required).
  groupAdminApprovedAt        DateTime?
  groupAdminApprovedById      String?
  /// Treasurer approval slot.
  treasurerApprovedAt         DateTime?
  treasurerApprovedById       String?
  rejectionReason             String?
  rejectedAt                  DateTime?
  rejectedByUserId            String?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupAdminApprovedBy User? @relation("LoanAppGroupAdmin", fields: [groupAdminApprovedById], references: [id], onDelete: SetNull)
  treasurerApprovedBy  User? @relation("LoanAppTreasurer", fields: [treasurerApprovedById], references: [id], onDelete: SetNull)
  rejectedBy           User? @relation("LoanAppRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  memberLoan            MemberLoan?

  @@index([groupId, userId])
  @@index([userId, status])
  @@map("loan_applications")
}

/// An approved and disbursed loan (created when both approvers have signed off).
model MemberLoan {
  id                          String   @id @default(cuid())
  userId                      String
  groupId                     String
  applicationId               String   @unique
  /// Principal disbursed to the member.
  principalAmount             Decimal  @db.Decimal(10, 2)
  /// Total to repay = principal + interest (flat, from snapshots at approval).
  totalRepayable              Decimal  @db.Decimal(10, 2)
  amountRepaid                Decimal  @default(0) @db.Decimal(10, 2)
  currency                    String   @default("RWF")
  interestRateSnapshot        Decimal  @db.Decimal(5, 2)
  repaymentPeriodDaysSnapshot Int
  disbursedAt                 DateTime @default(now())
  dueDate                     DateTime
  status                      MemberLoanStatus @default(ACTIVE)
  /// Server-maintained late/overdue fee bucket (e.g. when past due with penalty rules).
  penaltyAccrued              Decimal  @default(0) @db.Decimal(10, 2)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  depositRecords DepositRecord[]

  @@index([groupId, userId, status])
  @@map("member_loans")
}

/// Record of a member deposit intent (e.g. MoMo push or manual); amounts split for UI/audit.
model DepositRecord {
  id                    String                 @id @default(cuid())
  userId                String
  groupId               String
  amount                Decimal                @db.Decimal(10, 2)
  currency              String                 @default("RWF")
  contributionPortion   Decimal              @db.Decimal(10, 2)
  finePortion           Decimal                @default(0) @db.Decimal(10, 2)
  installmentPortion    Decimal                @default(0) @db.Decimal(10, 2)
  paymentMethod         DepositPaymentMethod
  phone                 String?
  status                DepositRecordStatus    @default(PENDING)
  /// Public URL of payment proof (receipt/screenshot) after upload; required for manual flow.
  proofImageUrl         String?
  rejectionReason       String?
  reviewedAt            DateTime?
  reviewedByUserId      String?
  createdAt             DateTime               @default(now())

  /// When set, this payment applies to `MemberLoan` repayment (not group contribution rules).
  memberLoanId String?
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  memberLoan  MemberLoan? @relation(fields: [memberLoanId], references: [id], onDelete: SetNull)
  reviewedBy User?  @relation("DepositReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([groupId, status])
  @@index([groupId, userId])
  @@index([memberLoanId])
  @@map("deposit_records")
}