generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  USER
  SUPER_ADMIN
  GROUP_ADMIN
  TREASURER
  MEMBER
}

enum GroupMembershipStatus {
  ACTIVE
  SUSPENDED
}

enum GroupRemovalKind {
  REMOVED
  SUSPENDED
}

enum ContributionStatus {
  PENDING
  PAID
  LATE
}

enum ContributionInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum LoanApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DepositPaymentMethod {
  MTN_MOMO
  MANUAL_TRANSFER
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  phoneNumber  String?
  image        String?
  isActive     Boolean @default(true)
  /// Set true after sign-up OTP or treasurer invitation completion.
  emailVerified              Boolean   @default(false)
  emailVerificationOtpHash   String?
  emailVerificationExpiresAt DateTime?
  passwordResetOtpHash       String?
  passwordResetExpiresAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  platformRoles UserPlatformRole[]
  userGroups    UserGroup[]
  createdGroups Group[]            @relation("GroupCreator")
  treasurerInvitations TreasurerInvitation[]
  memberInvitations    MemberInvitation[]
  groupRemovalNotifications GroupRemovalNotification[]
  contributions Contribution[]
  loanApplications  LoanApplication[]
  depositRecords      DepositRecord[]

  @@map("users")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean @default(false)
  createdById String
  isVerified  Boolean  @default(true)

  minMembers  Int
  createdAt   DateTime @default(now())

  createdBy  User         @relation("GroupCreator", fields: [createdById], references: [id])
  userGroups UserGroup[]
  loanConfig LoanConfig?
  contributionConfig ContributionConfig?

  treasurerInvitations TreasurerInvitation[]
  memberInvitations    MemberInvitation[]
  contributions        Contribution[]
  loanApplications     LoanApplication[]
  depositRecords       DepositRecord[]

  @@index([createdById])
  @@map("groups")
}

model Contribution {
  id        String   @id @default(cuid())
  userId    String
  groupId   String

  amount    Decimal  @db.Decimal(10, 2)
  dueDate   DateTime
  paidAt    DateTime?

  status    ContributionStatus @default(PENDING)

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, dueDate])
  @@index([groupId, dueDate])

  @@map("contributions")
}

model ContributionConfig {
  id        String @id @default(cuid())
  groupId   String @unique

  amount    Decimal @db.Decimal(10, 2)
  currency  String  @default("RWF")

  interval  ContributionInterval

  // Scheduling
  startDate DateTime
  dayOfWeek Int?   // 0–6 (for weekly/biweekly)
  dayOfMonth Int?  // 1–31 (for monthly)

  // Rules
  allowPartialPayments Boolean @default(false)
  latePenaltyRate      Decimal? @db.Decimal(5,2)
  gracePeriodDays      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("contribution_config")
}

/// One-time link for a pending treasurer to complete registration after group creation.
model TreasurerInvitation {
  id        String   @id @default(cuid())
  token     String   @unique
  groupId   String
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("treasurer_invitations")
}

/// One-time link for a pending member to complete registration after a group admin invite.
model MemberInvitation {
  id        String   @id @default(cuid())
  token     String   @unique
  groupId   String
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("member_invitations")
}

model Role {
  id   String   @id @default(cuid())
  name RoleName @unique

  platformAssignments UserPlatformRole[]
  userGroups          UserGroup[]

  @@map("roles")
}

/// Group membership: one role per user per group (relational RBAC).
model UserGroup {
  id                 String                 @id @default(cuid())
  userId             String
  groupId            String
  roleId             String
  joinedAt           DateTime               @default(now())
  membershipStatus   GroupMembershipStatus  @default(ACTIVE)
  customContributionAmount Decimal? @db.Decimal(10,2)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id])

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])

  @@map("user_groups")
}

/// In-app notice when a user is removed or suspended from a group (platform login unaffected).
model GroupRemovalNotification {
  id        String           @id @default(cuid())
  userId    String
  groupId   String
  groupName String
  kind      GroupRemovalKind
  reason    String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("group_removal_notifications")
}

/// Platform-level role: default `USER`, elevated e.g. `SUPER_ADMIN`. Not tied to a group.
model UserPlatformRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@unique([userId])

  @@map("user_platform_role")
}

model LoanConfig {
  id                     String   @id @default(cuid())
  groupId                String   @unique

  interestRate           Decimal  @db.Decimal(5, 2)
  repaymentPeriodDays    Int

  allowExceedContribution Boolean @default(false)
  maxLoanMultiplier       Decimal? @db.Decimal(5, 2)

  allowPartialPayments    Boolean  @default(true)

  penaltyRate             Decimal? @db.Decimal(5, 2)
  gracePeriodDays         Int      @default(0)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("loan_config")
}

/// Member request for a loan; validated against `LoanConfig` and contribution totals.
model LoanApplication {
  id                          String                 @id @default(cuid())
  userId                      String
  groupId                     String
  requestedAmount             Decimal                @db.Decimal(10, 2)
  status                      LoanApplicationStatus  @default(PENDING)
  interestRateSnapshot        Decimal                @db.Decimal(5, 2)
  repaymentPeriodDaysSnapshot Int
  /// Max allowed at request time (audit / explain eligibility).
  maxAmountSnapshot           Decimal?               @db.Decimal(10, 2)
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, userId])
  @@index([userId, status])
  @@map("loan_applications")
}

/// Record of a member deposit intent (e.g. MoMo push or manual); amounts split for UI/audit.
model DepositRecord {
  id                    String                @id @default(cuid())
  userId                String
  groupId               String
  amount                Decimal               @db.Decimal(10, 2)
  currency              String                @default("RWF")
  contributionPortion   Decimal               @db.Decimal(10, 2)
  finePortion           Decimal               @default(0) @db.Decimal(10, 2)
  installmentPortion    Decimal               @default(0) @db.Decimal(10, 2)
  paymentMethod         DepositPaymentMethod
  /// E.164 or local; required for `MTN_MOMO` at submit time.
  phone                 String?
  /// PENDING = recorded; later can hook MoMo callback → COMPLETED.
  status                String                @default("PENDING")
  createdAt             DateTime              @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, userId])
  @@map("deposit_records")
}