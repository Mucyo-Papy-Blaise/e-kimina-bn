generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  USER
  SUPER_ADMIN
  GROUP_ADMIN
  TREASURER
  MEMBER
}

enum GroupMembershipStatus {
  ACTIVE
  SUSPENDED
}

enum GroupRemovalKind {
  REMOVED
  SUSPENDED
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  phoneNumber  String?
  image        String?
  isActive     Boolean @default(true)
  /// Set true after sign-up OTP or treasurer invitation completion.
  emailVerified              Boolean   @default(false)
  emailVerificationOtpHash   String?
  emailVerificationExpiresAt DateTime?
  passwordResetOtpHash       String?
  passwordResetExpiresAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  platformRoles UserPlatformRole[]
  userGroups    UserGroup[]
  createdGroups Group[]            @relation("GroupCreator")
  treasurerInvitations TreasurerInvitation[]
  memberInvitations    MemberInvitation[]
  groupRemovalNotifications GroupRemovalNotification[]

  @@map("users")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean @default(false)
  createdById String
  isVerified  Boolean  @default(true)
  minMembers  Int
  createdAt   DateTime @default(now())

  createdBy  User         @relation("GroupCreator", fields: [createdById], references: [id])
  userGroups UserGroup[]
  loanConfig LoanConfig?
  treasurerInvitations TreasurerInvitation[]
  memberInvitations    MemberInvitation[]

  @@index([createdById])
  @@map("groups")
}

/// One-time link for a pending treasurer to complete registration after group creation.
model TreasurerInvitation {
  id        String   @id @default(cuid())
  token     String   @unique
  groupId   String
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("treasurer_invitations")
}

/// One-time link for a pending member to complete registration after a group admin invite.
model MemberInvitation {
  id        String   @id @default(cuid())
  token     String   @unique
  groupId   String
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("member_invitations")
}

model Role {
  id   String   @id @default(cuid())
  name RoleName @unique

  platformAssignments UserPlatformRole[]
  userGroups          UserGroup[]

  @@map("roles")
}

/// Group membership: one role per user per group (relational RBAC).
model UserGroup {
  id                 String                 @id @default(cuid())
  userId             String
  groupId            String
  roleId             String
  joinedAt           DateTime               @default(now())
  membershipStatus   GroupMembershipStatus  @default(ACTIVE)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id])

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])

  @@map("user_groups")
}

/// In-app notice when a user is removed or suspended from a group (platform login unaffected).
model GroupRemovalNotification {
  id        String           @id @default(cuid())
  userId    String
  groupId   String
  groupName String
  kind      GroupRemovalKind
  reason    String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("group_removal_notifications")
}

/// Platform-level role: default `USER`, elevated e.g. `SUPER_ADMIN`. Not tied to a group.
model UserPlatformRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@unique([userId])

  @@map("user_platform_role")
}

model LoanConfig {
  id                   String   @id @default(cuid())
  groupId              String   @unique
  interestRate         Decimal  @db.Decimal(8, 5)
  maxLoanAmount        Decimal  @db.Decimal(14, 2)
  repaymentPeriodDays  Int
  penaltyRate          Decimal  @db.Decimal(8, 5)
  allowPartialPayments Boolean
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("loan_config")
}
